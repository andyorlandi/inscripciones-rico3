# Admin password for accessing /admin panel
ADMIN_PASSWORD=admin123

# Database URL (PostgreSQL en Neon)
# IMPORTANTE: Local y producción usan la MISMA base de datos
# Copiar desde .env.production o desde Neon dashboard
DATABASE_URL="postgresql://usuario:password@host.neon.tech/nombredb?sslmode=require"

# Opcional: Project ID de Neon
NEON_PROJECT_ID="tu-project-id"
